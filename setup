#!/bin/bash
# Three Man Team setup script

echo ""
echo "========================================="
echo "  Three Man Team"
echo "========================================="
echo ""

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
GLOBAL_CLAUDE="$HOME/.claude"
GLOBAL_CLAUDE_MD="$GLOBAL_CLAUDE/CLAUDE.md"

# Detect project root for per-project installs
PARENT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
if [ "$PARENT_DIR" != "$HOME" ]; then
  PROJECT_ROOT="$PARENT_DIR"
else
  PROJECT_ROOT="/path/to/your/project"
fi

# Create global skills directory if needed
mkdir -p "$GLOBAL_CLAUDE/skills"

# Check for Claude Code
if command -v claude &> /dev/null; then
  echo "✓ Claude Code detected"
else
  echo "  Claude Code not found — install from https://claude.ai/code for slash command support"
fi

echo ""
echo "Welcome to Three Man Team."
echo ""
echo "Here is how this works:"
echo ""
echo "  You just cloned Three Man Team into a hidden .claude folder inside your"
echo "  project. Next we need to copy the agent files and handoff folder into"
echo "  your project root so your AI can find them."
echo ""
echo "  But first — your project file."
echo ""
echo "-----------------------------------------"
echo "  Step 1 — Your project file"
echo "-----------------------------------------"
echo ""
echo "  This is the file your AI reads at the start of every session — CLAUDE.md"
echo "  for Claude Code, or equivalent for other tools."
echo ""
echo "  Do you already have a project file?"
echo ""
echo "  NO — Create one now and paste this into it:"
echo ""
echo "    ## Three Man Team"
echo "    Available agents: /architect, /builder, /reviewer"
echo ""
echo "    ## Project"
echo "    [Describe your project here — what it does, who uses it, your stack]"
echo ""
echo "  YES — Add only this to your existing file:"
echo ""
echo "    ## Three Man Team"
echo "    Available agents: /architect, /builder, /reviewer"
echo ""
echo "  Do not copy your project file — paste the snippet into it."
echo ""
echo "-----------------------------------------"
echo "  Step 2 — Copy agent files into your project"
echo "-----------------------------------------"
echo ""
echo "  Run this command:"
echo ""
echo "  cp -r $SCRIPT_DIR/templates/project-folder/* $PROJECT_ROOT/"
echo ""
echo "  This adds ARCHITECT.md, BUILDER.md, REVIEWER.md, and the handoff/ folder"
echo "  to your project root. These are the files your agents read and write."
echo ""
echo "-----------------------------------------"
echo "  Step 3 — Start your first session"
echo "-----------------------------------------"
echo ""
echo '  Open Claude Code in your project folder and paste:'
echo ""
echo '  You are the Architect on this project. Read CLAUDE.md, then ARCHITECT.md.'
echo ""
echo "  See examples/session-start.md for more prompts."
echo ""
