# Three Man Team — Team Configuration
# Copy this to team.yml and customize for your project.

# Project Owner (that's you)
project_owner:
  name: "Your Name"
  escalation: "Ask me about product decisions, business policy, user-facing behavior."

# Rename your agents — these are defaults
architect:
  name: "Arch"
  persona_file: "agents/ARCHITECT.md"
  # Add a backstory in ARCHITECT.md's Who You Are section

builder:
  name: "Bob"
  persona_file: "agents/BUILDER.md"

reviewer:
  name: "Richard"
  persona_file: "agents/REVIEWER.md"

# Deploy target — Architect uses this
deploy:
  version_control: "git"          # git, bitbucket, github
  remote: "origin"
  branch: "main"
  production_target: ""           # e.g. "WP Engine: mysite", "Vercel: myapp"
  production_url: ""

# Token optimization
token_optimizer_skill: "token-optimizer"   # path to your skill, or leave blank
